# ─── LLM Proxy ───────────────────────────────────────────────────────────────
# Local: points to free-claude-code proxy (run it first: cd free-claude-code && uv run python server.py)
# Railway: set to the deployed proxy service URL
LLM_BASE_URL=http://localhost:8082

# Proxy accepts any non-empty value; set a real key if using Anthropic API directly
ANTHROPIC_API_KEY=dummy-proxied

# ─── Model IDs (proxy maps these to NIM/backend models) ───────────────────────
MODEL_OPUS=claude-opus-4-6
MODEL_SONNET=claude-sonnet-4-6
MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID — only this user can send requests to the bot.
# Get yours by messaging @userinfobot on Telegram.
# Leave empty to allow all users (not recommended for production).
ALLOWED_TELEGRAM_USER_ID=your_telegram_user_id

# ─── Web UI ───────────────────────────────────────────────────────────────────
# 브라우저 접속 시 입력할 비밀번호
WEB_PASSWORD=your-password-here
# Railway가 자동으로 PORT를 주입함 — 로컬에서는 8000이 기본값
# PORT=8000

# ─── Storage ──────────────────────────────────────────────────────────────────
OUTPUTS_DIR=outputs

# ─── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
